{
  "name": "winmerge-vscode",
  "displayName": "WinMerge VS Code",
  "description": "Compare two folders and open file diffs with the native VS Code diff editor",
  "version": "0.0.1",
  "publisher": "joaoraenke",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "winmerge-vscode.compareFolders",
        "title": "WinMerge: Compare Folders"
      },
      {
        "command": "winmerge-vscode.copyDiffToLeft",
        "title": "WinMerge: Copy Diff to Left"
      },
      {
        "command": "winmerge-vscode.copyDiffToRight",
        "title": "WinMerge: Copy Diff to Right"
      }
    ],
    "keybindings": [
      {
        "command": "winmerge-vscode.copyDiffToLeft",
        "key": "ctrl+alt+left",
        "when": "isInDiffEditor && textInputFocus"
      },
      {
        "command": "winmerge-vscode.copyDiffToRight",
        "key": "ctrl+alt+right",
        "when": "isInDiffEditor && textInputFocus"
      }
    ],
    "viewContainers": {
      "activitybar": [
        {
          "id": "winmerge-sidebar-container",
          "title": "WinMerge Compare",
          "icon": "resources/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "winmerge-sidebar-container": [
        {
          "type": "webview",
          "id": "winmerge-vscode-sidebar",
          "name": "WinMerge Compare",
          "icon": "resources/icon-sidebar.svg"
        }
      ]
    },
    "configurationDefaults": {
      "files.associations": {
        "*.pas.tmp": "objectpascal",
        "*.tmp.pas": "objectpascal",
        "*.pas.base": "objectpascal",
        "*.dfm.tmp": "objectpascal",
        "*.tmp.dfm": "objectpascal",
        "*.dfm": "objectpascal",
        "*.pas": "objectpascal"
      },
      "[objectpascal]": {
        "files.encoding": "windows1252"
      },
      "[pascal]": {
        "files.encoding": "windows1252"
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "dir-compare": "^4.0.0",
    "fs-extra": "^11.3.4",
    "jschardet": "^3.1.4"
  }
}
